{% extends 'base.html.twig' %}

{% block title %}InnovShop - Accueil{% endblock %}

{% block body %}
    <div class="mt-5 px-5">
        <div class="h-[300px] mx-auto rounded-3xl overflow-hidden max-w-6xl bg-linear-to-t from-sky-500 to-blue-700">
            <div class="flex flex-col justify-center gap-10 items-center h-full py-auto text-center text-white">
                <h1 class="font-bold text-6xl">InnovShop</h1>
                <div></div>
                <p class="font-semibold text-2xl row-start-3 row-end-4">Le site e-commerce au service de l'innovation technologique</p>
            </div>
        </div>

        <!-- Produits à la une -->
        <section class="my-10 py-5 max-w-6xl mx-auto rounded-3xl">
            <h2 class="text-center font-bold text-3xl mb-10">Produits à la une</h2>
            <div class="flex flex-wrap justify-center gap-10">
            {% for product in uneProducts %}
                <article class="rounded-3xl flex flex-col shadow-lg shadow-blue-700 w-2xs">
                    <div class="w-full h-[200px]">
                        <a href="{{ path('app_products_detail', {id: product.id, slug: product.slug }) }}">
                            {% if (product.image)%}
                            <img src="{{ asset('uploads/' ~ product.image) }}" alt="{{ product.title }}" class="rounded-t-3xl object-cover w-full h-full">
                            {% else %}
                            <div class="flex justify-center items-center h-full w-full text-6xl text-neutral-400 bg-white rounded-t-3xl">
                                <i class="fa-solid fa-image"></i>
                            </div>
                            {% endif %}
                        </a>
                    </div>
                    <div class="mx-5 h-[250px] flex flex-col justify-between">
                        <h3 class="font-semibold text-center text-lg mt-3"><a href="{{ path('app_products_detail', {id: product.id, slug: product.slug }) }}">{{ product.title }}{% if product.option|length > 0 %} - {{ product.option|first }}{% endif %}</a></h3>
                        {% if product.option|length > 1 %}
                        <p class="text-xs text-green-700 text-center italic">{{ product.option|length }} options disponibles</p>
                        {% endif %}
                        <div class="text-black text-justify my-3 line-clamp-3">
                            <p>{{ product.description|raw }}</p>
                        </div>
                        <div class="flex justify-between items-center my-3 gap-3">
                            {% if (product.stock > 0) %}
                            <p class="font-semibold text-lg">{{ product.price|number_format(2, ',', ' ') }} €</p>
                            
                                {% if cart and cart.orderLines|length > 0 %}  {# Si client + panier #}
                                    {% set productInCart = false %}
                                    {% for line in cart.orderLines %}
                                        {% if line.product.id == product.id %}
                                            {% set productInCart = line %}
                                        {% endif %}
                                    {% endfor %}
                                    {% if productInCart %}
                                        <div class="grid grid-cols-3">
                                            <form method="post" action="{{ path('app_products_remove_to_cart', {id: product.id}) }}">
                                                <input type="hidden" name="quantity" value="1">
                                                <input type="hidden" name="redirect" value="{{ app.request.uri }}">
                                                <button type="submit" class="border border-blue-700 hover:bg-blue-700 rounded-3xl text-black text-lg px-2 cursor-pointer">
                                                    {% if productInCart.quantity > 1 %}
                                                        <i class="fa-solid fa-minus"></i>
                                                    {% else %}
                                                        <i class="fa-solid fa-trash"></i>
                                                    {% endif %}
                                                </button>
                                            </form>
                                            <p class="text-lg text-center font-semibold text-black">{{ productInCart.quantity }}</p>
                                            <form method="post" action="{{ path('app_products_add_to_cart', {id: product.id}) }}" class="justify-center flex flex-col">
                                                <input type="hidden" name="quantity" value="1">
                                                <input type="hidden" name="redirect" value="{{ app.request.uri }}">
                                                {% if productInCart.quantity < product.stock %}
                                                    <button type="submit" class="border border-blue-700 hover:bg-blue-700 rounded-3xl text-black text-lg px-2 cursor-pointer">
                                                        <i class="fa-solid fa-plus"></i>
                                                    </button>
                                                {% else %}
                                                    <p class="text-xs text-center text-black">MAX</p>
                                                {% endif %}
                                            </form>
                                        </div>
                                    {% else %}
                                        <form method="post" action="{{ path('app_products_add_to_cart', {id: product.id}) }}">
                                            <input type="hidden" name="quantity" value="1">
                                            <input type="hidden" name="redirect" value="{{ app.request.uri }}">
                                            <button type="submit" class="border border-blue-700 hover:bg-blue-700 text-black text-xl rounded-3xl px-2 cursor-pointer"><i class="fa-solid fa-cart-plus"></i></button>
                                        </form>
                                    {% endif %}
                                
                                {% else %} {# Si pas de panier #}
                                    <form method="post" action="{{path('app_products_add_to_cart', {id: product.id})}}">
                                        <input type="hidden" name="quantity" value="1">
                                        <input type="hidden" name="redirect" value="{{ app.request.uri }}">
                                        <button type="submit" class="border border-blue-700 hover:bg-blue-700 text-black text-xl rounded-3xl px-2 cursor-pointer"><i class="fa-solid fa-cart-plus"></i></button>
                                    </form>
                                {% endif %}
                            {% else %}
                            <p class="text-lg text-black">{{ product.price|number_format(2, ',', ' ') }} €</p>
                            <p class="text-red-700 text-sm font-bold">Rupture de stock</p>
                            {% endif %}
                        </div>
                    </div>
                </article>
                {% endfor %}   
            </div>
        </section>

        <!-- Nouveautés -->
        <section class="my-10 py-5 max-w-6xl mx-auto rounded-3xl">
            <h2 class="text-center font-bold text-3xl mb-10">Nouveautés</h2>
            <div class="flex flex-wrap justify-center gap-10">
                {% for product in newProducts %}
                <article class="rounded-3xl flex flex-col shadow-lg shadow-blue-700 w-2xs">
                    <div class="w-full h-[200px]">
                        <a href="{{ path('app_products_detail', {id: product.id, slug: product.slug }) }}">
                            {% if (product.image)%}
                            <img src="{{ asset('uploads/' ~ product.image) }}" alt="{{ product.title }}" class="rounded-t-3xl object-cover w-full h-full">
                            {% else %}
                            <div class="flex justify-center items-center h-full w-full text-6xl text-neutral-400 bg-white rounded-t-3xl">
                                <i class="fa-solid fa-image"></i>
                            </div>
                            {% endif %}
                        </a>
                    </div>
                    <div class="mx-5 h-[250px] flex flex-col justify-between">
                        <h3 class="font-semibold text-center text-xl mt-3"><a href="{{ path('app_products_detail', {id: product.id, slug: product.slug }) }}">{{ product.title }}{% if product.option|length > 0 %} - {{ product.option|first }}{% endif %}</a></h3>
                        {% if product.option|length > 1 %}
                        <p class="text-xs text-green-700 text-center italic">{{ product.option|length }} options disponibles</p>
                        {% endif %}
                        <div class="text-black text-justify my-3 line-clamp-3">
                            <p>{{ product.description|raw }}</p>
                        </div>
                        <div class="flex justify-between items-center my-3 gap-3">
                            {% if (product.stock > 0) %}
                            <p class="font-semibold text-lg">{{ product.price|number_format(2, ',', ' ') }} €</p>
                            
                                {% if cart and cart.orderLines|length > 0 %}  {# Si client + panier #}
                                    {% set productInCart = false %}
                                    {% for line in cart.orderLines %}
                                        {% if line.product.id == product.id %}
                                            {% set productInCart = line %}
                                        {% endif %}
                                    {% endfor %}
                                    {% if productInCart %}
                                        <div class="grid grid-cols-3">
                                            <form method="post" action="{{ path('app_products_remove_to_cart', {id: product.id}) }}">
                                                <input type="hidden" name="quantity" value="1">
                                                <input type="hidden" name="redirect" value="{{ app.request.uri }}">
                                                <button type="submit" class="border border-blue-700 hover:bg-blue-700 rounded-3xl text-black text-lg px-2 cursor-pointer">
                                                    {% if productInCart.quantity > 1 %}
                                                        <i class="fa-solid fa-minus"></i>
                                                    {% else %}
                                                        <i class="fa-solid fa-trash"></i>
                                                    {% endif %}
                                                </button>
                                            </form>
                                            <p class="text-lg text-center font-semibold text-black">{{ productInCart.quantity }}</p>
                                            <form method="post" action="{{ path('app_products_add_to_cart', {id: product.id}) }}" class="justify-center flex flex-col">
                                                <input type="hidden" name="quantity" value="1">
                                                <input type="hidden" name="redirect" value="{{ app.request.uri }}">
                                                {% if productInCart.quantity < product.stock %}
                                                    <button type="submit" class="border border-blue-700 hover:bg-blue-700 rounded-3xl text-black text-lg px-2 cursor-pointer">
                                                        <i class="fa-solid fa-plus"></i>
                                                    </button>
                                                {% else %}
                                                    <p class="text-xs text-center text-black">MAX</p>
                                                {% endif %}
                                            </form>
                                        </div>
                                    {% else %}
                                        <form method="post" action="{{ path('app_products_add_to_cart', {id: product.id}) }}">
                                            <input type="hidden" name="quantity" value="1">
                                            <input type="hidden" name="redirect" value="{{ app.request.uri }}">
                                            <button type="submit" class="border border-blue-700 hover:bg-blue-700 text-black text-xl rounded-3xl px-2 cursor-pointer"><i class="fa-solid fa-cart-plus"></i></button>
                                        </form>
                                    {% endif %}
                                
                                {% else %} {# Si pas de panier #}
                                    <form method="post" action="{{path('app_products_add_to_cart', {id: product.id})}}">
                                        <input type="hidden" name="quantity" value="1">
                                        <input type="hidden" name="redirect" value="{{ app.request.uri }}">
                                        <button type="submit" class="border border-blue-700 hover:bg-blue-700 text-black text-xl rounded-3xl px-2 cursor-pointer"><i class="fa-solid fa-cart-plus"></i></button>
                                    </form>
                                {% endif %}
                            {% else %}
                            <p class="text-lg text-black">{{ product.price|number_format(2, ',', ' ') }} €</p>
                            <p class="text-red-700 text-sm font-bold">Rupture de stock</p>
                            {% endif %}
                        </div>
                    </div>
                </article>
                {% endfor %}                   
            </div>
        </section>
    </div>
{% endblock %}
